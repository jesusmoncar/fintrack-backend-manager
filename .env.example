# Entorno de Flask
FLASK_ENV=development
FLASK_PORT=5001

# Secret key (genera una clave segura para producción)
SECRET_KEY=cambia-esto-por-una-clave-segura

# Base de datos MySQL (Docker)
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=
DB_NAME=gestor_inversiones

# Configuración regional
TIMEZONE=Europe/Madrid
LOCALE=es_ES

# Logging
LOG_LEVEL=INFO
